	"compatibility_date": "2026-06-18",
	"observability": {
		"enabled": true
	},
	"upload_source_maps": true,
	"compatibility_flags": [
		"nodejs_compat"
	],
	"vars": {
		"AD_ACCOUNT": "act_359318456016031"
	}
}
